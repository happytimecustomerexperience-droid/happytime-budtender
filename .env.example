# ── Happy Time Budtender — environment ───────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env. All values stay on the VPS.

# Django
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,budtender.internal
# The website's server-side origin(s) that call this API (for CSRF/CORS hygiene).
CSRF_TRUSTED_ORIGINS=https://happytimeweed.com

# Shared service token — the Next.js site sends `Authorization: Bearer <this>`.
# Must equal HHT_BACKEND_TOKEN configured on the website (server-only env there).
HHT_BACKEND_TOKEN=change-me-long-random-service-token

# Postgres (this service owns its OWN database)
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=budtender
SQL_USER=budtender
SQL_PASSWORD=change-me
SQL_HOST=db
SQL_PORT=5432
SQL_CONN_MAX_AGE=60          # persistent DB connections (concurrency)

# Gunicorn concurrency (rule of thumb: WORKERS = 2 * vCPU + 1).
# 2 vCPU VPS → 5 workers × 4 threads handles hundreds of concurrent chat users.
GUNICORN_WORKERS=5
GUNICORN_THREADS=4

# Redis / Celery
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_BACKEND_URL=redis://redis:6379/0

# Cloudflare Tunnel (no inbound ports on the VPS). Token from `cloudflared`.
TUNNEL_TOKEN=

# ── Dutchie credentials (copy per-store values from marketing_dashboard) ──────
# POS REST (HTTP Basic; key used as username). Per store, read-only.
DUTCHIE_YAKIMA_POS_KEY=
DUTCHIE_MTVERNON_POS_KEY=
DUTCHIE_PULLMAN_POS_KEY=
# Backoffice GraphQL inventory (optional path) — location + LSP ids + a user pool.
DUTCHIE_YAKIMA_LOC_ID=
DUTCHIE_YAKIMA_LSP_ID=
DUTCHIE_MTVERNON_LOC_ID=
DUTCHIE_MTVERNON_LSP_ID=
DUTCHIE_PULLMAN_LOC_ID=
DUTCHIE_PULLMAN_LSP_ID=
# JSON array of backoffice users for the round-robin pool (optional):
# [{"username":"...","password":"...","user_id":101}, ...]
DUTCHIE_BACKOFFICE_USERS=[]
DUTCHIE_BACKOFFICE_BASE_URL=https://ash.backoffice.dutchie.com/

# Observability (optional)
SENTRY_DSN=
