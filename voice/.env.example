# Happy Time Voice Agent — env catalog (03-CONVENTIONS.md §3).
# Per-store Dutchie keys live in the budtender service's env, NOT here (ADR-004/019).
# NOTE: comments are on their own lines — an inline "KEY=  # ..." on an EMPTY value
# is parsed by python-dotenv as the value itself, so keep comments above the var.
#
# ── MERGED REPO (lives under happytime-budtender/voice/) ───────────────────
# Copy this to voice/.env and fill the secrets. When started via the REPO-ROOT
# `docker compose up -d`, the root docker-compose.yml FORCES these four so they
# are correct no matter what this file says:
#     POSTGRES_HOST=voice-db   DJANGO_DEBUG=0   HTTPS_ENABLED=1
#     HHT_BUDTENDER_BASE_URL=http://budtender.internal:8000   (budtender, in-cluster)
# Everything else (secrets, hostnames, email) you set HERE.

# ── 3.1 Django framework ───────────────────────────────────────────────
# Django secret. Non-default required in prod (fail-closed).
DJANGO_SECRET_KEY=dev-insecure-change-me
# 1 dev / 0 prod (prod hardens + fails closed).
DJANGO_DEBUG=1
# Comma-separated hostnames. Include the public host + the in-cluster service name.
DJANGO_ALLOWED_HOSTS=voice.happytimeweed.com,voice-web,localhost,127.0.0.1
# Dashboard origins (the API webhook is HMAC, not cookie). e.g. https://voice.happytimeweed.com
CSRF_TRUSTED_ORIGINS=https://voice.happytimeweed.com
# Public HTTPS base Vapi tools call back to.
PUBLIC_BASE_URL=https://voice.happytimeweed.com

# ── 3.2 Database (Postgres; matches docker-compose) ────────────────────
# NOTE: voice-db (root compose) reads POSTGRES_DB/USER/PASSWORD from THIS file,
# so whatever you set here is what the DB is created with — voice-web matches it.
POSTGRES_DB=happytime_voice
POSTGRES_USER=happytime_voice
POSTGRES_PASSWORD=change-me
# In the merged stack the root compose forces this to "voice-db" (the DB container).
POSTGRES_HOST=voice-db
POSTGRES_PORT=5432

# ── 3.3 Vapi surface (VAPI_*) ──────────────────────────────────────────
# Vapi private API key — Authorization: Bearer. Provision + publish.
VAPI_PRIVATE_KEY=
# Shared secret/HMAC key to verify inbound Vapi webhooks (fail-closed).
VAPI_WEBHOOK_SECRET=
# Id of the provisioned Squad (written back by provision_vapi.py).
VAPI_SQUAD_ID=
# Inbound number id fronting the Squad (O-4 placeholder).
VAPI_PHONE_NUMBER_ID=
# Cartesia sonic-3 voice id (Koptza).
VAPI_VOICE_ID=a3520a8f-226a-428d-9fcd-b0a4711a6829
# Single intentional assistant model (ADR-010).
VAPI_ASSISTANT_MODEL=gpt-4.1-mini
# Webhook auth header names (env-driven; exact Vapi header is config, not code).
# Mode A: hex hmac-sha256(secret, raw_body).
VAPI_SIGNATURE_HEADER=X-Vapi-Signature
# Mode B: server.secret echo.
VAPI_SECRET_HEADER=X-Vapi-Secret

# ── 3.4 budtender microservice (HHT_*) ─────────────────────────────────
# Base URL of happytime-budtender. In the merged stack the root compose forces
# this to the in-cluster address below (no tunnel hop). `budtender.internal` is a
# docker network alias of budtender's web container (see root docker-compose.yml).
HHT_BUDTENDER_BASE_URL=http://budtender.internal:8000
# Bearer service token shared with budtender (constant-time). Must equal budtender's.
HHT_BACKEND_TOKEN=change-me-long-random-service-token
# HTTP timeout (s) for budtender calls.
HHT_BUDTENDER_TIMEOUT=8

# ── 3.5 Transfer / phone routing (HHT_TRANSFER_*) — O-4 placeholders ────
HHT_TRANSFER_NUMBER_YAKIMA=+15095711106
HHT_TRANSFER_NUMBER_MTVERNON=+13604882923
HHT_TRANSFER_NUMBER_PULLMAN=+15093342788
# Store assumed when caller hasn't specified.
HHT_DEFAULT_STORE=yakima

# ── 3.5b Post-call queue (P5, gated; OPTIONAL) ─────────────────────────
# Off by default → post-call summary/email/rollup run INLINE (P2 behavior); the durable VoiceCall
# write is ALWAYS synchronous. Set to 1 + run a Celery worker (`celery -A core worker`) + Redis to
# move that work off the webhook turn.
# Set to 1 AND run `docker compose --profile voice-async up -d` to offload post-call work.
HHT_USE_CELERY=0
# Merged stack: the optional voice-redis container.
CELERY_BROKER_URL=redis://voice-redis:6379/0
CELERY_WORKER_CONCURRENCY=2

# ── 3.6 Gemini / Vertex (server-side LLM; GEMINI_*/GOOGLE_*) ────────────
# Prefer Vertex AI (data residency) over the API-key path.
GEMINI_USE_VERTEX=True
# GCP project for Vertex (owner-supplied).
GOOGLE_CLOUD_PROJECT=
# Vertex region.
GOOGLE_CLOUD_LOCATION=us-central1
# Path to SA JSON (or use ADC).
GOOGLE_APPLICATION_CREDENTIALS=
# Dev fallback consumer key (AI Studio).
GEMINI_API_KEY=
# swedish-bot fail-closed flag; US store → 1.
ALLOW_NON_EU_RESIDENCY=1

# ── 3.7 Email / staff alerts (EMAIL_*/STAFF_ALERT_*) — O-9 placeholders ─
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
# From address for alerts.
LEAD_EMAIL_FROM=bot@happytimeweed.com
# Default staff alert sink (shared).
STAFF_ALERT_EMAIL=happytimeyak509@gmail.com
# Per-store overrides (optional).
STAFF_ALERT_EMAIL_YAKIMA=
STAFF_ALERT_EMAIL_MTVERNON=
STAFF_ALERT_EMAIL_PULLMAN=

# ── 3.8 Slack (optional secondary sink; SLACK_*) — O-9 placeholder ──────
# Incoming-webhook URL for the optional Slack sink.
SLACK_WEBHOOK_URL=
# 0 until a webhook is supplied.
SLACK_ALERTS_ENABLED=0

# ── 3.9 Security / PII ─────────────────────────────────────────────────
# MUST differ from DJANGO_SECRET_KEY (fail-closed).
PHONE_HASH_PEPPER=dev-pepper-change-me
# 1 in prod behind real TLS (HSTS + secure cookies).
HTTPS_ENABLED=0
# Webhook/tool rate-limit window (s).
RATE_LIMIT_WINDOW=300

# ── 3.10 Dutchie — reference ONLY (these live in budtender, NOT here) ───
# In happytime-budtender/.env: DUTCHIE_YAKIMA_POS_KEY, DUTCHIE_MTVERNON_POS_KEY,
# DUTCHIE_PULLMAN_POS_KEY (HTTP Basic, key as username; read-only). Per ADR-004/019
# the voice repo never holds a Dutchie key.
